<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="GuiEcad_App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GuiEcad_App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    KeyDown="OnKeyDown"
    KeyUp="OnKeyUp"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- ツールバー RadioButton スタイル（サークル非表示・フラットボタン風） -->
        <Style x:Key="ToolBtnStyle" TargetType="RadioButton">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="Root"
                            Padding="{TemplateBinding Padding}"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="4">
                            <VisualStateManager.VisualStateGroups>
                                <!-- ToggleButton/RadioButton の状態は単一グループで扱う。
                                     チェックとホバーを別グループに分けると両者が Background を奪い合い、
                                     選択中ボタンにマウスオーバーするとアクセント色が消えてしまうため、
                                     CheckedPointerOver/CheckedPressed の複合状態を明示する。 -->
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="Root"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="Root"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled" />
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="Root"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="Root"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource AccentFillColorSecondaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="Root"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource AccentFillColorTertiaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="CheckedDisabled" />
                                    <VisualState x:Name="Indeterminate" />
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" KeyboardAcceleratorPlacementMode="Hidden">
        <Grid.KeyboardAccelerators>
            <!-- Enter は予約キー（機器名編集起動／キーボード配置モードの配置確定の二重用途で文脈分岐するため、
                 ショートカットキー設定機能ではカスタマイズ対象外＝常にこの固定登録のまま）。
                 それ以外のカスタマイズ可能なコマンド（Undo/Redo/削除/保存/検索/コメント編集/行操作/コピペ/
                 ツール切替F5-F8/ズーム/新規/開く）は MainPage.KeyBindings.cs が起動時に動的登録する。 -->
            <KeyboardAccelerator Key="Enter" Invoked="OnEnterAccelerator" />
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <MenuBar x:Name="TopMenuBar" Grid.Row="0" Background="{ThemeResource AppToolbarBackgroundBrush}">
            <MenuBarItem Title="ファイル(F)">
                <MenuFlyoutItem Text="新規(N)" KeyboardAcceleratorTextOverride="Ctrl+N" Click="OnMenuNew" />
                <MenuFlyoutItem Text="テンプレートから新規作成..." Click="OnMenuNewFromTemplate" />
                <MenuFlyoutItem Text="開く(O)..." KeyboardAcceleratorTextOverride="Ctrl+O" Click="OnMenuOpen" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="上書き保存(S)" KeyboardAcceleratorTextOverride="Ctrl+S" Click="OnMenuSave" />
                <MenuFlyoutItem Text="名前を付けて保存(A)..." Click="OnMenuSaveAs" />
                <MenuFlyoutItem Text="テンプレートとして保存..." Click="OnMenuSaveAsTemplate" />
                <MenuFlyoutItem Text="オートセーブ設定..." Click="OnMenuAutosaveSettings" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="PDF プレビュー..." Click="OnMenuPreviewPdf" />
                <MenuFlyoutItem Text="PDF出力..." Click="OnMenuExportPdf" />
            </MenuBarItem>
            <MenuBarItem Title="編集(E)">
                <MenuFlyoutItem Text="元に戻す(U)" KeyboardAcceleratorTextOverride="Ctrl+Z" Click="OnMenuUndo" />
                <MenuFlyoutItem Text="やり直し(R)" KeyboardAcceleratorTextOverride="Ctrl+Y" Click="OnMenuRedo" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="検索・置換(F)..." KeyboardAcceleratorTextOverride="Ctrl+F" Click="OnMenuFind" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="削除(D)" KeyboardAcceleratorTextOverride="Del" Click="OnDelete" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="ショートカットキー設定..." Click="OnMenuKeyBindingSettings" />
            </MenuBarItem>
            <MenuBarItem Title="図面(D)">
                <MenuFlyoutItem Text="ドキュメント情報..." Click="OnDocumentInfo" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="シート設定..." Click="OnSheetSettings" />
                <MenuFlyoutItem Text="部品リスト(BOM)..." Click="OnBomEditor" />
            </MenuBarItem>
            <MenuBarItem Title="表示(V)">
                <MenuFlyoutItem Text="拡大(+)" KeyboardAcceleratorTextOverride="Ctrl++" Click="OnZoomIn" />
                <MenuFlyoutItem Text="縮小(-)" KeyboardAcceleratorTextOverride="Ctrl+-" Click="OnZoomOut" />
                <MenuFlyoutItem Text="全体表示" KeyboardAcceleratorTextOverride="Ctrl+0" Click="OnFit" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="DevicePanelMenuItem" Text="機器表を表示" Click="OnDevicePanelToggle" />
                <ToggleMenuFlyoutItem x:Name="GridMenuItem" Text="グリッド表示" Click="OnGridToggle" />
                <MenuFlyoutSeparator />
                <ToggleMenuFlyoutItem x:Name="DarkModeMenuItem" Text="ダークモード" Click="OnDarkModeToggle" />
                <ToggleMenuFlyoutItem x:Name="CanvasDarkModeItem" Text="ダークモード(作図色)" Click="OnCanvasDarkToggle" />
            </MenuBarItem>
            <MenuBarItem x:Name="ShapeMenuBarItem" Title="図形(G)" />
            <MenuBarItem Title="ヘルプ(H)">
                <MenuFlyoutItem Text="使い方..." Click="OnMenuHowTo" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="バージョン情報..." Click="OnMenuAbout" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="RestartMenuItem" Text="再ビルドして再起動" Click="OnMenuRestart" />
            </MenuBarItem>
        </MenuBar>

        <!-- 標準ツールバー (P5: 操作系ボタン) -->
        <Border
            x:Name="ToolbarBorder"
            Grid.Row="1"
            Background="{ThemeResource AppToolbarBackgroundBrush}"
            BorderBrush="{ThemeResource AppDividerBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Padding="4,2" Spacing="2" VerticalAlignment="Center">
                <!-- モード切替 -->
                <ToggleButton x:Name="TestModeBtn" AutomationProperties.AutomationId="TestModeBtn"
                              VerticalAlignment="Center" Click="OnTestModeToggle"
                              Content="&#x25B6; テスト" FontWeight="SemiBold"
                              Padding="10,5" MinWidth="80" />
                <Rectangle Margin="4,2" Fill="{ThemeResource AppDividerBrush}" VerticalAlignment="Stretch" Width="1" />
                <!-- キーボード配置モード（マウスレス配置。矢印キーでフォーカスセル移動・数字キーでツール選択・Enterで配置）。
                     IsTabStop=False: このボタンがキーボードフォーカスを保持すると、モード中の Enter キーが
                     ボタン自身の既定動作（トグルOFF）に奪われてしまうため、フォーカスを持たせない。 -->
                <ToggleButton x:Name="KeyboardModeBtn" AutomationProperties.AutomationId="KeyboardModeBtn"
                              VerticalAlignment="Center" Click="OnKeyboardModeToggle" IsTabStop="False"
                              Content="&#x2328; キー配置" ToolTipService.ToolTip="キーボード配置モード（矢印キー移動・数字キーでツール選択・Enterで配置・Escで終了）"
                              Padding="10,5" />
                <TextBlock x:Name="KeyboardModeHint" VerticalAlignment="Center" FontSize="11" Margin="6,0,0,0"
                           Visibility="Collapsed"
                           Text="1:a接点 2:b接点 3:コイル 4:PB-NO 5:PB-NC 6:限時a 7:限時b 8:表示灯 9:端子台 0:選択" />
                <Rectangle Margin="4,2" Fill="{ThemeResource AppDividerBrush}" VerticalAlignment="Stretch" Width="1" />
                <!-- Undo / Redo -->
                <Button VerticalAlignment="Center" Click="OnMenuUndo" ToolTipService.ToolTip="元に戻す (Ctrl+Z)">
                    <FontIcon Glyph="&#xE7A7;" FontSize="14" />
                </Button>
                <Button VerticalAlignment="Center" Click="OnMenuRedo" ToolTipService.ToolTip="やり直し (Ctrl+Y)">
                    <FontIcon Glyph="&#xE7A6;" FontSize="14" />
                </Button>
                <Rectangle Margin="4,2" Fill="{ThemeResource AppDividerBrush}" VerticalAlignment="Stretch" Width="1" />
                <!-- 削除 -->
                <Button VerticalAlignment="Center" Click="OnDelete" ToolTipService.ToolTip="選択削除 (Del)">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                </Button>
                <Rectangle Margin="4,2" Fill="{ThemeResource AppDividerBrush}" VerticalAlignment="Stretch" Width="1" />
                <!-- 接続検査 -->
                <ToggleButton x:Name="ConnectivityToggle" AutomationProperties.AutomationId="ConnectivityToggle" VerticalAlignment="Center" Click="OnConnectivityToggle" Content="接続検査" />
                <Rectangle Margin="4,2" Fill="{ThemeResource AppDividerBrush}" VerticalAlignment="Stretch" Width="1" />
                <!-- ズーム -->
                <Button VerticalAlignment="Center" Click="OnZoomIn" ToolTipService.ToolTip="拡大 (Ctrl++)">
                    <FontIcon Glyph="&#xE8A3;" FontSize="14" />
                </Button>
                <Button VerticalAlignment="Center" Click="OnZoomOut" ToolTipService.ToolTip="縮小 (Ctrl+-)">
                    <FontIcon Glyph="&#xE71F;" FontSize="14" />
                </Button>
                <Button VerticalAlignment="Center" Click="OnFit" ToolTipService.ToolTip="全体表示 (Ctrl+0)">
                    <FontIcon Glyph="&#xE9A6;" FontSize="14" />
                </Button>
                <Rectangle Margin="4,2" Fill="{ThemeResource AppDividerBrush}" VerticalAlignment="Stretch" Width="1" />
                <!-- 列 -->
                <Button VerticalAlignment="Center" Click="OnRemoveColumn" Content="列－" ToolTipService.ToolTip="列を減らす" />
                <Button VerticalAlignment="Center" Click="OnAddColumn" Content="列＋" ToolTipService.ToolTip="列を増やす" />
                <Rectangle Margin="4,2" Fill="{ThemeResource AppDividerBrush}" VerticalAlignment="Stretch" Width="1" />
                <!-- 行 -->
                <Button VerticalAlignment="Center" Click="OnInsertRowBtn" Content="行＋" ToolTipService.ToolTip="末尾に行追加 (Ctrl+Shift+↑)" />
                <Button VerticalAlignment="Center" Click="OnDeleteRowBtn" Content="行－" ToolTipService.ToolTip="末尾の行削除 (Ctrl+Shift+↓)" />
                <Rectangle Margin="4,2" Fill="{ThemeResource AppDividerBrush}" VerticalAlignment="Stretch" Width="1" />
                <!-- PDF プレビュー -->
                <Button VerticalAlignment="Center" Click="OnMenuPreviewPdf" ToolTipService.ToolTip="PDF プレビュー">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <FontIcon Glyph="&#xE8A4;" FontSize="14" />
                        <TextBlock Text="プレビュー" VerticalAlignment="Center" FontSize="11" />
                    </StackPanel>
                </Button>
                <!-- PDF -->
                <Button VerticalAlignment="Center" Click="OnMenuExportPdf" ToolTipService.ToolTip="PDF出力">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <FontIcon Glyph="&#xEA90;" FontSize="14" />
                        <TextBlock Text="PDF" VerticalAlignment="Center" FontSize="11" />
                    </StackPanel>
                </Button>
                <!-- タイマ時限（テストモード時のみ有効・実時間で自動カウント） -->
                <StackPanel x:Name="TimerTickPanel" Orientation="Horizontal" Spacing="4"
                            VerticalAlignment="Center" Visibility="Collapsed">
                    <Rectangle Margin="4,2" Fill="{ThemeResource AppDividerBrush}" VerticalAlignment="Stretch" Width="1" />
                    <TextBlock Text="タイマ実時間計時" VerticalAlignment="Center" FontSize="12" />
                    <ToggleButton x:Name="TimerPauseBtn" Content="一時停止" Click="OnTimerPauseToggle"
                                  ToolTipService.ToolTip="タイマの実時間カウントを一時停止/再開" />
                </StackPanel>
            </StackPanel>
        </Border>


        <!-- メインエリア（縦パレット + ナビツリー + 作図エリア + 右パネル） -->
        <Grid x:Name="MainAreaGrid" Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ToolDockColumn" Width="Auto" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 縦ツールパレット (P1)：ドックホスト。フロート時は中身(ToolScroll)を ToolPaletteFloat へ移動 -->
            <Border
                x:Name="ToolDockHost"
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Background="{ThemeResource AppPaletteBackgroundBrush}"
                BorderBrush="{ThemeResource AppDividerBrush}"
                BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <!-- ドック時ヘッダ（切り離しボタン） -->
                    <Border Grid.Row="0" Background="{ThemeResource AppPanelHeaderBrush}">
                        <Grid>
                            <TextBlock Text="ツール" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0" />
                            <Button HorizontalAlignment="Right" Padding="4,0" Margin="0,1" FontSize="11"
                                    Click="OnPaletteDockToggle" Content="&#x21F1;"
                                    ToolTipService.ToolTip="パレットを切り離す（フロート）" />
                        </Grid>
                    </Border>
                    <Border x:Name="ToolDockContent" Grid.Row="1">
                <ScrollViewer x:Name="ToolScroll" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ToolStackPanel" Orientation="Vertical" Padding="2" Spacing="1" Width="64">
                        <!-- 選択ツール -->
                        <RadioButton
                            x:Name="BtnSelect"
                            AutomationProperties.AutomationId="BtnSelect"
                            GroupName="Tools"
                            IsChecked="True"
                            Style="{StaticResource ToolBtnStyle}"
                            Tag="select"
                            Checked="OnToolSelected">
                            <StackPanel>
                                <TextBlock Width="44" FontSize="18" HorizontalAlignment="Center" Text="↖" TextAlignment="Center" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="選択" />
                            </StackPanel>
                        </RadioButton>
                        <Rectangle Height="1" Margin="4,1" Fill="{ThemeResource AppDividerBrush}" />
                        <!-- 接点系 -->
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolBtnStyle}" Tag="ContactNO" Checked="OnToolSelected">
                            <StackPanel>
                                <Image x:Name="IconContactNO" Width="44" Height="32" Stretch="Uniform" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="a接点" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolBtnStyle}" Tag="ContactNC" Checked="OnToolSelected">
                            <StackPanel>
                                <Image x:Name="IconContactNC" Width="44" Height="32" Stretch="Uniform" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="b接点" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolBtnStyle}" Tag="PushButtonNO" Checked="OnToolSelected">
                            <StackPanel>
                                <Image x:Name="IconPushButtonNO" Width="44" Height="32" Stretch="Uniform" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="押釦NO" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolBtnStyle}" Tag="PushButtonNC" Checked="OnToolSelected">
                            <StackPanel>
                                <Image x:Name="IconPushButtonNC" Width="44" Height="32" Stretch="Uniform" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="押釦NC" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolBtnStyle}" Tag="TimerContactNO" Checked="OnToolSelected">
                            <StackPanel>
                                <Image x:Name="IconTimerContactNO" Width="44" Height="32" Stretch="Uniform" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="タイマNO" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolBtnStyle}" Tag="TimerContactNC" Checked="OnToolSelected">
                            <StackPanel>
                                <Image x:Name="IconTimerContactNC" Width="44" Height="32" Stretch="Uniform" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="タイマNC" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolBtnStyle}" Tag="TimerInstantContactNO" Checked="OnToolSelected">
                            <StackPanel>
                                <Image x:Name="IconTimerInstantContactNO" Width="44" Height="32" Stretch="Uniform" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="瞬時NO" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolBtnStyle}" Tag="TimerInstantContactNC" Checked="OnToolSelected">
                            <StackPanel>
                                <Image x:Name="IconTimerInstantContactNC" Width="44" Height="32" Stretch="Uniform" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="瞬時NC" />
                            </StackPanel>
                        </RadioButton>
                        <Rectangle Height="1" Margin="4,1" Fill="{ThemeResource AppDividerBrush}" />
                        <!-- 出力系 -->
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolBtnStyle}" Tag="Coil" Checked="OnToolSelected">
                            <StackPanel>
                                <Image x:Name="IconCoil" Width="44" Height="32" Stretch="Uniform" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="コイル" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolBtnStyle}" Tag="Lamp" Checked="OnToolSelected">
                            <StackPanel>
                                <Image x:Name="IconLamp" Width="44" Height="32" Stretch="Uniform" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="表示灯" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolBtnStyle}" Tag="Terminal" Checked="OnToolSelected">
                            <StackPanel>
                                <Image x:Name="IconTerminal" Width="44" Height="32" Stretch="Uniform" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="端子" />
                            </StackPanel>
                        </RadioButton>
                        <Rectangle Height="1" Margin="4,1" Fill="{ThemeResource AppDividerBrush}" />
                        <!-- 特殊 -->
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolBtnStyle}" Tag="connector"
                                     Checked="OnToolSelected" ToolTipService.ToolTip="縦コネクタ（並列分岐）：列の交点を上から下へドラッグ">
                            <StackPanel>
                                <TextBlock Width="44" Height="32" FontSize="22" HorizontalAlignment="Center" TextAlignment="Center" Text="&#x2503;" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="分岐" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolBtnStyle}" Tag="wirebreak"
                                     Checked="OnToolSelected" ToolTipService.ToolTip="配線分断（非接続）：同一行の自動横配線をセル中央で断ち切る。クリックで配置/解除">
                            <StackPanel>
                                <TextBlock Width="44" Height="32" FontSize="20" HorizontalAlignment="Center" TextAlignment="Center" Text="&#x2702;" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="分断" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolBtnStyle}" Tag="frame"
                                     Checked="OnToolSelected" ToolTipService.ToolTip="設置場所枠（ドラッグで矩形作成・ダブルタップでラベル編集）">
                            <StackPanel>
                                <TextBlock Width="44" Height="32" FontSize="18" HorizontalAlignment="Center" TextAlignment="Center" Text="&#x25A1;" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="枠" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolBtnStyle}" Tag="line"
                                     Checked="OnToolSelected" ToolTipService.ToolTip="自由直線（主回路の母線・結線。格子点に吸着して2点ドラッグ）">
                            <StackPanel>
                                <TextBlock Width="44" Height="32" FontSize="22" HorizontalAlignment="Center" TextAlignment="Center" Text="&#x2571;" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="直線" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolBtnStyle}" Tag="dot"
                                     Checked="OnToolSelected" ToolTipService.ToolTip="接続点（●）。縦横の線の交点などに1クリックで配置（格子点に吸着）">
                            <StackPanel>
                                <TextBlock Width="44" Height="32" FontSize="20" HorizontalAlignment="Center" TextAlignment="Center" Text="&#x25CF;" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="点" />
                            </StackPanel>
                        </RadioButton>
                        <Button HorizontalAlignment="Center" FontSize="11" Click="OnInsertImageClick"
                                ToolTipService.ToolTip="画像挿入（BMP/PNG）：トレース用下絵または恒久貼付として配置">
                            <StackPanel>
                                <TextBlock Width="44" Height="32" FontSize="20" HorizontalAlignment="Center" TextAlignment="Center" Text="画" />
                                <TextBlock FontSize="10" HorizontalAlignment="Center" Text="画像" />
                            </StackPanel>
                        </Button>
                        <Rectangle Height="1" Margin="4,1" Fill="{ThemeResource AppDividerBrush}" />
                        <!-- その他 -->
                        <DropDownButton x:Name="OtherPartButton" HorizontalAlignment="Center" FontSize="11" Content="その他▼"
                                        ToolTipService.ToolTip="セレクトSW・サーマル等">
                            <DropDownButton.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="セレクトSW" Tag="SelectSwitch" Click="OnOtherPartSelected" />
                                    <MenuFlyoutItem Text="サーマル(OL)" Tag="ThermalOverload" Click="OnOtherPartSelected" />
                                    <MenuFlyoutItem Text="非常停止" Tag="EmergencyStop" Click="OnOtherPartSelected" />
                                    <MenuFlyoutItem Text="三相モータ" Tag="Motor" Click="OnOtherPartSelected" />
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                    </StackPanel>
                </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <!-- ナビゲーションツリー (P2) -->
            <Border
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="1"
                BorderBrush="{ThemeResource AppDividerBrush}"
                BorderThickness="0,0,1,0"
                Background="{ThemeResource AppPanelBackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{ThemeResource AppPanelHeaderBrush}">
                        <TextBlock Text="シート" FontSize="11" FontWeight="SemiBold" Padding="8,5" />
                    </Border>
                    <TreeView
                        x:Name="NavTree"
                        Grid.Row="1"
                        SelectionMode="Single"
                        SelectionChanged="OnNavTreeSelectionChanged"
                        DoubleTapped="OnNavTreeDoubleTapped" />
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4" Padding="4,3">
                        <Button FontSize="14" Padding="6,2" Click="OnAddSheetBtn" ToolTipService.ToolTip="シートを追加">＋</Button>
                        <Button FontSize="14" Padding="6,2" Click="OnDeleteSheetBtn" ToolTipService.ToolTip="シートを削除">－</Button>
                        <Button FontSize="11" Padding="6,2" Click="OnRenameSheetBtn" ToolTipService.ToolTip="シート名を変更">名前</Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 検索・置換バー（Ctrl+F で表示・作図エリア上部に表示） -->
            <Border
                x:Name="FindBar"
                Grid.Row="0"
                Grid.Column="2"
                Grid.ColumnSpan="2"
                Visibility="Collapsed"
                Background="{ThemeResource AppToolbarBackgroundBrush}"
                BorderBrush="{ThemeResource AppDividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,3">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBox
                        x:Name="FindBox"
                        Width="130"
                        PlaceholderText="機器名を検索"
                        KeyDown="OnFindBoxKeyDown"
                        TextChanged="OnFindBoxTextChanged" />
                    <Button Click="OnFindPrev" ToolTipService.ToolTip="前の一致"><FontIcon Glyph="&#xE76B;" FontSize="12" /></Button>
                    <Button Click="OnFindNext" ToolTipService.ToolTip="次の一致"><FontIcon Glyph="&#xE76C;" FontSize="12" /></Button>
                    <TextBlock
                        x:Name="FindStatus"
                        VerticalAlignment="Center"
                        FontSize="11"
                        MinWidth="40"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Rectangle
                        Width="1"
                        Margin="4,2"
                        Fill="{ThemeResource AppDividerBrush}"
                        VerticalAlignment="Stretch" />
                    <TextBox x:Name="ReplaceBox" Width="130" PlaceholderText="置換後の機器名" />
                    <Button Content="置換" Click="OnReplaceOne" />
                    <Button Content="全置換" Click="OnReplaceAll" />
                    <Button Click="OnFindClose" ToolTipService.ToolTip="閉じる"><FontIcon Glyph="&#xE8BB;" FontSize="12" /></Button>
                </StackPanel>
            </Border>

            <!-- Canvas + インラインテキストオーバーレイ。上下端ドック帯（横ツールバー）でキャンバスを押し下げる -->
            <Grid Grid.Row="1" Grid.Column="2" Background="{ThemeResource AppCanvasBackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 上端ドック帯（横並びツールバー） -->
                <Border
                    x:Name="ToolTopDock"
                    Grid.Row="0"
                    Visibility="Collapsed"
                    Background="{ThemeResource AppPaletteBackgroundBrush}"
                    BorderBrush="{ThemeResource AppDividerBrush}"
                    BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" VerticalAlignment="Center" Padding="4,0" Margin="2,0" FontSize="11"
                                Click="OnPaletteDockToggle" Content="&#x21F2;"
                                ToolTipService.ToolTip="切り離す（フロート）" />
                        <Border x:Name="ToolTopDockContent" Grid.Column="1" />
                    </Grid>
                </Border>

                <canvas:CanvasControl
                    x:Name="Canvas"
                    Grid.Row="1"
                    Draw="OnDraw"
                    PointerMoved="OnPointerMoved"
                    PointerPressed="OnPointerPressed"
                    PointerReleased="OnPointerReleased"
                    PointerWheelChanged="OnPointerWheel"
                    PointerCaptureLost="OnPointerCaptureLost"
                    RightTapped="OnCanvasRightTapped" />
                <!-- 機器名インライン入力 -->
                <TextBox
                    x:Name="DeviceNameBox"
                    Grid.Row="1"
                    Visibility="Collapsed"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Width="90"
                    FontSize="12"
                    Padding="4,2"
                    KeyDown="OnDeviceNameBoxKeyDown"
                    LostFocus="OnDeviceNameBoxLostFocus" />
                <!-- 枠ラベルインライン入力 -->
                <TextBox
                    x:Name="FrameLabelBox"
                    Grid.Row="1"
                    Visibility="Collapsed"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Width="120"
                    FontSize="12"
                    Padding="4,2"
                    PlaceholderText="ラベル（例: 中継BOX）"
                    KeyDown="OnFrameLabelBoxKeyDown"
                    LostFocus="OnFrameLabelBoxLostFocus" />
                <!-- コメントインライン入力 (F2) -->
                <TextBox
                    x:Name="CommentBox"
                    Grid.Row="1"
                    Visibility="Collapsed"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Width="90"
                    FontSize="11"
                    Padding="4,2"
                    PlaceholderText="コメント"
                    KeyDown="OnCommentBoxKeyDown"
                    LostFocus="OnCommentBoxLostFocus" />
                <!-- 行コメントインライン入力（右母線右側ダブルクリック） -->
                <TextBox
                    x:Name="RungCommentBox"
                    Grid.Row="1"
                    Visibility="Collapsed"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Width="140"
                    FontSize="12"
                    Padding="4,2"
                    PlaceholderText="行コメント"
                    KeyDown="OnRungCommentBoxKeyDown"
                    LostFocus="OnRungCommentBoxLostFocus" />

                <!-- 下端ドック帯（横並びツールバー） -->
                <Border
                    x:Name="ToolBottomDock"
                    Grid.Row="2"
                    Visibility="Collapsed"
                    Background="{ThemeResource AppPaletteBackgroundBrush}"
                    BorderBrush="{ThemeResource AppDividerBrush}"
                    BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" VerticalAlignment="Center" Padding="4,0" Margin="2,0" FontSize="11"
                                Click="OnPaletteDockToggle" Content="&#x21F2;"
                                ToolTipService.ToolTip="切り離す（フロート）" />
                        <Border x:Name="ToolBottomDockContent" Grid.Column="1" />
                    </Grid>
                </Border>

                <!-- フロートツールパレット用オーバーレイ（Background は x:Null：空き領域でポインタを奪わない） -->
                <Canvas x:Name="ToolOverlay" Grid.Row="1" Background="{x:Null}" SizeChanged="OnToolOverlaySizeChanged">
                    <!-- 上下端吸着プレビュー（ドラッグ中に吸着先を半透明帯で表示・ポインタ透過） -->
                    <Border
                        x:Name="ToolSnapPreview"
                        Canvas.Left="0"
                        Canvas.Top="0"
                        Visibility="Collapsed"
                        IsHitTestVisible="False"
                        Opacity="0.30"
                        Background="{ThemeResource AppStatusBarBackgroundBrush}"
                        BorderBrush="{ThemeResource AppStatusBarBackgroundBrush}"
                        BorderThickness="0,2" />
                    <Border
                        x:Name="ToolPaletteFloat"
                        Canvas.Left="4"
                        Canvas.Top="4"
                        Visibility="Collapsed"
                        Background="{ThemeResource AppPaletteBackgroundBrush}"
                        BorderBrush="{ThemeResource AppDividerBrush}"
                        BorderThickness="1"
                        CornerRadius="3">
                        <StackPanel Orientation="Vertical">
                            <!-- ドラッグ用タイトルバー -->
                            <Border
                                x:Name="ToolPaletteHandle"
                                Background="{ThemeResource AppToolbarBackgroundBrush}"
                                PointerPressed="OnPalettePressed"
                                PointerMoved="OnPaletteMoved"
                                PointerReleased="OnPaletteReleased">
                                <Grid>
                                    <TextBlock Text="ツール" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,2" />
                                    <Button HorizontalAlignment="Right" Padding="4,0" Margin="0,1" FontSize="11"
                                            Click="OnPaletteDockToggle" Content="&#x21F2;"
                                            ToolTipService.ToolTip="パレットを左にドック" />
                                </Grid>
                            </Border>
                            <!-- フロート時はここに ToolScroll が入る -->
                            <Border x:Name="ToolFloatContent" MaxHeight="640" />
                        </StackPanel>
                    </Border>
                </Canvas>
            </Grid>

            <!-- 下部出力パネル (P3) -->
            <Border
                x:Name="OutputPanel"
                Grid.Row="2"
                Grid.Column="1"
                Grid.ColumnSpan="3"
                Height="40"
                BorderBrush="{ThemeResource AppDividerBrush}"
                BorderThickness="0,1,0,0"
                Background="{ThemeResource AppPanelBackgroundBrush}">
                <TabView
                    x:Name="OutputTabView"
                    TabWidthMode="SizeToContent"
                    IsAddTabButtonVisible="False">
                    <TabView.TabStripFooter>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                            <Button
                                x:Name="OutputCollapseBtn"
                                Content="▲"
                                Padding="6,2"
                                FontSize="11"
                                Click="OnOutputPanelToggle"
                                ToolTipService.ToolTip="出力パネルを折りたたむ"
                                VerticalAlignment="Center" />
                            <TextBlock x:Name="HintText" FontSize="11" VerticalAlignment="Center"
                                       Opacity="0.55" IsTextSelectionEnabled="False" />
                        </StackPanel>
                    </TabView.TabStripFooter>

                    <!-- 回路エラータブ -->
                    <TabViewItem Header="回路エラー" IsClosable="False">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                Grid.Row="0"
                                BorderBrush="{ThemeResource AppDividerBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="4,2">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button Content="回路チェック" Click="OnRunDrc" />
                                    <TextBlock
                                        x:Name="DrcStatusText"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Border>
                            <ListView
                                x:Name="DrcListView"
                                Grid.Row="1"
                                SelectionChanged="OnDrcItemSelected"
                                SelectionMode="Single"
                                FontSize="11" />
                        </Grid>
                    </TabViewItem>

                    <!-- 検索結果タブ -->
                    <TabViewItem Header="検索結果" IsClosable="False">
                        <ListView
                            x:Name="SearchResultPanelView"
                            SelectionChanged="OnSearchResultItemSelected"
                            SelectionMode="Single"
                            FontSize="11" />
                    </TabViewItem>

                    <!-- 接続検査タブ -->
                    <TabViewItem Header="接続検査" IsClosable="False">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                Grid.Row="0"
                                BorderBrush="{ThemeResource AppDividerBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="4,2">
                                <Button Content="接続検査実行" Click="OnRunConnectivity" />
                            </Border>
                            <ListView
                                x:Name="ConnectivityListView"
                                Grid.Row="1"
                                FontSize="11" />
                        </Grid>
                    </TabViewItem>
                </TabView>
            </Border>

            <!-- 右ドックパネル (P4: タブ化) -->
            <Border
                x:Name="DevicePanel"
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="3"
                Width="0"
                Visibility="Collapsed"
                BorderBrush="{ThemeResource AppDividerBrush}"
                BorderThickness="1,0,0,0"
                Background="{ThemeResource AppPanelBackgroundBrush}">
                <TabView
                    x:Name="RightPanelTabView"
                    TabWidthMode="SizeToContent"
                    IsAddTabButtonVisible="False">
                    <!-- 機器表タブ -->
                    <TabViewItem Header="機器表" IsClosable="False">
                        <ListView
                            x:Name="DeviceListView"
                            SelectionChanged="OnDeviceListSelectionChanged"
                            SelectionMode="Single"
                            FontSize="11" />
                    </TabViewItem>
                    <!-- プロパティタブ -->
                    <TabViewItem x:Name="PropertiesTab" Header="プロパティ" IsClosable="False">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="PropertiesPanel" Padding="8" Spacing="6">
                                <TextBlock Text="要素を選択してください" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabViewItem>
                </TabView>
            </Border>

            <!-- 右端の細いサイドバー（常時表示・パネル開閉トグル） -->
            <Border
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="4"
                Background="{ThemeResource AppPaletteBackgroundBrush}"
                BorderBrush="{ThemeResource AppDividerBrush}"
                BorderThickness="1,0,0,0">
                <Grid Width="28">
                    <!-- 右パネル開閉（中央・三角ハンドル） -->
                    <Button
                        x:Name="RightPanelToggleBtn"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Click="OnRightPanelToggle"
                        Width="26" Height="270" Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTipService.ToolTip="プロパティ／機器表パネルの開閉">
                        <TextBlock x:Name="RightPanelToggleGlyph" Text="◀" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- ステータスバー (P6: 強化版) -->
        <Border
            Grid.Row="3"
            Background="{ThemeResource AppStatusBarBackgroundBrush}"
            BorderThickness="0"
            Padding="8,3">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Left">
                    <TextBlock
                        x:Name="StatusMode"
                        AutomationProperties.AutomationId="StatusMode"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Text="作画モード"
                        Foreground="{ThemeResource AppStatusBarForegroundBrush}"
                        VerticalAlignment="Center" />
                    <Rectangle Width="1" Margin="0,2" Fill="{ThemeResource AppStatusBarDividerBrush}" VerticalAlignment="Stretch" />
                    <TextBlock
                        x:Name="StatusPos"
                        FontSize="11"
                        Text="行: -  列: -"
                        Foreground="{ThemeResource AppStatusBarForegroundBrush}"
                        VerticalAlignment="Center" />
                    <Rectangle Width="1" Margin="0,2" Fill="{ThemeResource AppStatusBarDividerBrush}" VerticalAlignment="Stretch" />
                    <TextBlock
                        x:Name="StatusSheet"
                        AutomationProperties.AutomationId="StatusSheet"
                        FontSize="11"
                        Text="シート 1 / 1"
                        Foreground="{ThemeResource AppStatusBarForegroundBrush}"
                        VerticalAlignment="Center" />
                    <Rectangle Width="1" Margin="0,2" Fill="{ThemeResource AppStatusBarDividerBrush}" VerticalAlignment="Stretch" />
                    <TextBlock
                        x:Name="StatusDirty"
                        FontSize="11"
                        Text=""
                        Foreground="{ThemeResource AppStatusDirtyBrush}"
                        Visibility="Collapsed"
                        VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock
                    x:Name="StatusWarn"
                    FontSize="11"
                    Visibility="Collapsed"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource AppStatusWarnBrush}" />
            </Grid>
        </Border>
    </Grid>
</Page>
