<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="GuiEcad_App.PartEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GuiEcad_App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="自作パーツ作成"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 名前・基準範囲・役割 -->
        <Border
            Grid.Row="0"
            Padding="8,6"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="名前" VerticalAlignment="Center" />
                <TextBox x:Name="NameBox" Width="160" PlaceholderText="例: リミットSW" />

                <TextBlock Text="幅(セル)" VerticalAlignment="Center" />
                <NumberBox x:Name="WidthBox" Value="1" Minimum="1" Maximum="12"
                           SpinButtonPlacementMode="Inline" ValueChanged="OnSizeChanged" Width="110" />
                <TextBlock Text="高さ(セル)" VerticalAlignment="Center" />
                <NumberBox x:Name="HeightBox" Value="1" Minimum="1" Maximum="12"
                           SpinButtonPlacementMode="Inline" ValueChanged="OnSizeChanged" Width="110" />

                <TextBlock Text="役割" VerticalAlignment="Center" />
                <ComboBox x:Name="RoleBox" Width="150" SelectedIndex="0">
                    <ComboBoxItem Content="a接点 (NO)" Tag="ContactNO" />
                    <ComboBoxItem Content="b接点 (NC)" Tag="ContactNC" />
                    <ComboBoxItem Content="コイル" Tag="Coil" />
                    <ComboBoxItem Content="表示灯" Tag="Lamp" />
                    <ComboBoxItem Content="端子台" Tag="Terminal" />
                    <ComboBoxItem Content="非シミュレート" Tag="NonSimulated" />
                </ComboBox>

                <Rectangle Margin="6,2" Width="1" VerticalAlignment="Stretch"
                           Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                <DropDownButton Content="組込み図形を読み込み">
                    <DropDownButton.Flyout>
                        <MenuFlyout x:Name="TemplateFlyout" />
                    </DropDownButton.Flyout>
                </DropDownButton>
            </StackPanel>
        </Border>

        <!-- 描画ツールバー -->
        <Border
            Grid.Row="1"
            Padding="6,4"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel x:Name="DrawToolPanel" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                <RadioButton GroupName="DrawTools" Content="選択" Tag="select" IsChecked="True" Checked="OnDrawToolSelected" />
                <RadioButton GroupName="DrawTools" Content="線" Tag="line" Checked="OnDrawToolSelected" />
                <RadioButton GroupName="DrawTools" Content="折れ線" Tag="polyline" Checked="OnDrawToolSelected" />
                <RadioButton GroupName="DrawTools" Content="矩形" Tag="rect" Checked="OnDrawToolSelected" />
                <RadioButton GroupName="DrawTools" Content="円" Tag="circle" Checked="OnDrawToolSelected" />
                <RadioButton GroupName="DrawTools" Content="弧" Tag="arc" Checked="OnDrawToolSelected" />
                <RadioButton GroupName="DrawTools" Content="回転" Tag="rotate" Checked="OnDrawToolSelected" />
                <RadioButton GroupName="DrawTools" Content="文字" Tag="text" Checked="OnDrawToolSelected" />
                <RadioButton GroupName="DrawTools" Content="接続点" Tag="port" Checked="OnDrawToolSelected" />

                <Rectangle Margin="6,2" Width="1" VerticalAlignment="Stretch"
                           Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <Button Content="元に戻す" Click="OnUndo" />
                <Button Content="やり直し" Click="OnRedo" />
                <Button Content="選択を削除" Click="OnDeleteSelected" />

                <Rectangle Margin="6,2" Width="1" VerticalAlignment="Stretch"
                           Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <Button Content="拡大(+)" Click="OnZoomInPart" />
                <Button Content="縮小(-)" Click="OnZoomOutPart" />
                <Button Content="全体表示" Click="OnZoomFitPart" />
            </StackPanel>
        </Border>

        <!-- 描画キャンバス -->
        <canvas:CanvasControl
            x:Name="EditCanvas"
            Grid.Row="2"
            IsTabStop="True"
            Draw="OnDraw"
            PointerPressed="OnPointerPressed"
            PointerMoved="OnPointerMoved"
            PointerReleased="OnPointerReleased"
            PointerWheelChanged="OnPointerWheelChanged"
            KeyDown="OnCanvasKeyDown"
            KeyUp="OnCanvasKeyUp" />

        <!-- フッタ: 保存・閉じる -->
        <Border
            Grid.Row="3"
            Padding="8,6"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="ArcFlatLabel" Text="扁平率 ry/rx" VerticalAlignment="Center"
                           Visibility="Collapsed"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <NumberBox x:Name="ArcFlatBox" Width="120" Visibility="Collapsed"
                           Minimum="0.05" Maximum="20" SmallChange="0.05" LargeChange="0.25"
                           SpinButtonPlacementMode="Inline" ValueChanged="OnArcFlatChanged" />
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="保存" Style="{ThemeResource AccentButtonStyle}" Click="OnSave" />
                    <Button Content="閉じる" Click="OnClose" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
