<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="GuiEcad_App.PdfPreviewDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="PDF プレビュー"
    PrimaryButtonText="PDF 出力"
    CloseButtonText="閉じる"
    DefaultButton="Close">

    <StackPanel MinWidth="640">

        <!-- ツールバー行 -->
        <Border
            Padding="8,4"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">

                <!-- ページ移動 -->
                <Button x:Name="PrevBtn" Content="◀" Width="36" Click="OnPrev" />
                <TextBlock x:Name="PageLabel" VerticalAlignment="Center" MinWidth="80" TextAlignment="Center" FontSize="13" />
                <Button x:Name="NextBtn" Content="▶" Width="36" Click="OnNext" />

                <!-- 区切り -->
                <Border Width="1" Height="20" Margin="6,0"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!-- ズーム操作 -->
                <Button x:Name="ZoomOutBtn" Content="−" Width="36" Click="OnZoomOut" />
                <TextBlock x:Name="ZoomLabel" VerticalAlignment="Center" MinWidth="52" TextAlignment="Center" FontSize="13" />
                <Button x:Name="ZoomInBtn" Content="＋" Width="36" Click="OnZoomIn" />
                <Button x:Name="FitBtn" Content="幅に合わせる" Padding="8,4" Click="OnFitWidth" />

            </StackPanel>
        </Border>

        <!-- キャンバス領域 -->
        <ScrollViewer
            x:Name="Scroll"
            Height="560"
            Background="#FF6E6E6E"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto">

            <canvas:CanvasControl
                x:Name="PreviewCanvas"
                MinWidth="400"
                HorizontalAlignment="Stretch"
                Draw="OnCanvasDraw"
                SizeChanged="OnCanvasSizeChanged" />

        </ScrollViewer>

    </StackPanel>
</ContentDialog>
